{
  "name": "clawtensor",
  "version": "1.4.1",
  "description": "ClawTensor — MCP server bridging AI agents to Bittensor's decentralized AI network",
  "main": "build/index.js",
  "bin": {
    "clawtensor": "build/index.js"
  },
  "files": [
    "build/",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"const f='build/index.js';const c=require('fs').readFileSync(f,'utf8');if(!c.startsWith('#!'))require('fs').writeFileSync(f,'#!/usr/bin/env node\\n'+c)\"",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "bittensor",
    "decentralized-ai",
    "clawtensor",
    "model-context-protocol",
    "tao"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/claudusprojects/clawtensor"
  },
  "homepage": "https://clawtensor.tech",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@polkadot/api": "^12.0.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0"
  }
}